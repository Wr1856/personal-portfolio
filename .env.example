# --- Site -------------------------------------------------------------------
# Full public URL of the deployment (Preview: the Vercel URL; Production: the
# final domain). Used for canonical links, sitemap, Open Graph, and JSON-LD.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Feature flag reserved for the v2 AI assistant. Keep false in v1.
NEXT_PUBLIC_WESLEY_AI_ENABLED=false

# --- Supabase ----------------------------------------------------------------
# Project URL and anon key (Dashboard → Settings → API). Safe for the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key. SERVER ONLY — never expose in the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin -------------------------------------------------------------------
# The only e-mail allowed into /admin. Also enforced by RLS (admin_emails).
ADMIN_EMAIL=

# --- Cloudflare Turnstile ------------------------------------------------------
# Widget site key (public) and secret key (server-side validation).
# Test keys for development: site 1x00000000000000000000AA / secret 1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
